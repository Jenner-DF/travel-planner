datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
  schemas  = ["public"]  // <-- do NOT include auth
}

model Trip {
  id          String      @id @default(uuid())
  title       String
  description String
  imageUrl    String
  startDate   DateTime
  endDate     DateTime
  userId      String      @db.Uuid  // just store UUID, no @relation
  locations   Location[]
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  @@schema("public")
}

model Location {
  id            String   @id @default(uuid())
  locationTitle String
  lat           Float
  long          Float
  address       String
  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId        String
  order         Int      @default(0)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@schema("public")
}