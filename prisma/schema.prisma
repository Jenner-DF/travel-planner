datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model Trip {
  id          String     @id @default(uuid()) @db.Uuid
  title       String
  description String
  imageUrl    String
  startDate   DateTime
  endDate     DateTime

  // StackAuth user id
  userId      String     @db.Uuid

  locations   Location[]

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([userId]) // important for fast queries per user
}

model Location {
  id            String   @id @default(uuid()) @db.Uuid
  locationTitle String
  lat           Float
  long          Float
  address       String

  trip          Trip     @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripId        String   @db.Uuid

  order         Int      @default(0)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([tripId])
}